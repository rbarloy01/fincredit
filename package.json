{
  "name": "finanalyzer---ai-financial-modeling-&-covenants",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "npm run lint && esbuild tests/*.test.ts --bundle --platform=node --format=esm --define:import.meta.env.VITE_SUPABASE_URL='\"http://localhost\"' --define:import.meta.env.VITE_SUPABASE_ANON_KEY='\"test-key\"' --outdir=/tmp/finmonitor-tests && node --test /tmp/finmonitor-tests/*.js",
    "verify:numbers": "esbuild scripts/verify-number-normalization.ts --bundle --platform=node --format=cjs --define:import.meta.env.VITE_SUPABASE_URL='\"http://localhost\"' --define:import.meta.env.VITE_SUPABASE_ANON_KEY='\"verification-key\"' --outfile=/tmp/finmonitor-number-verification.cjs && node /tmp/finmonitor-number-verification.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@rollup/wasm-node": "^4.60.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.2.1",
    "exceljs": "^4.4.0",
    "googleapis": "^173.0.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^1.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
